from sklearn.model_selection import RandomizedSearchCV
from sklearn.pipeline import Pipeline
from scipy.stats import loguniform


def run_baselines_hyperparameter_tuning(train_df, test_df):

    print("Preparing Data...")

    X_train_text = train_df["text"]
    X_test_text  = test_df["text"]

    y_train = train_df[LABEL_COL].values
    y_test  = test_df[LABEL_COL].values


    print("\nTuning Logistic Regression...")

    pipe_lr = Pipeline([
        ("tfidf", TfidfVectorizer()),
        ("clf", LogisticRegression(
            max_iter=2000,
            class_weight="balanced",
            n_jobs=-1
        ))
    ])

    param_lr = {
        "tfidf__max_features": [15000, 25000],
        "tfidf__ngram_range": [(1,1), (1,2)],
        "clf__C": loguniform(0.01, 10),
        "clf__solver": ["liblinear", "lbfgs"]
    }

    search_lr = RandomizedSearchCV(
        pipe_lr,
        param_distributions=param_lr,
        n_iter=5,                 # FAST
        scoring="f1",
        cv=3,
        verbose=1,
        n_jobs=-1,
        random_state=42
    )

    search_lr.fit(X_train_text, y_train)

    best_lr = search_lr.best_estimator_

    print("Best LR Params:", search_lr.best_params_)

    pred = best_lr.predict(X_test_text)
    probs = best_lr.predict_proba(X_test_text)[:,1]

    evaluate(y_test, pred, probs, "Tuned TFIDF + Logistic Regression")

    print("\nTuning LinearSVC...")

    pipe_svm = Pipeline([
        ("tfidf", TfidfVectorizer()),
        ("clf", LinearSVC(
            class_weight="balanced"
        ))
    ])

    param_svm = {
        "tfidf__max_features": [15000, 25000],
        "tfidf__ngram_range": [(1,1), (1,2)],
        "clf__C": loguniform(0.01, 10)
    }

    search_svm = RandomizedSearchCV(
        pipe_svm,
        param_distributions=param_svm,
        n_iter=5,                 # FAST
        scoring="f1",
        cv=3,
        verbose=1,
        n_jobs=-1,
        random_state=42
    )

    search_svm.fit(X_train_text, y_train)

    best_svm_raw = search_svm.best_estimator_

    print("Best SVM Params:", search_svm.best_params_)

    # Calibrate best SVM
    print("Calibrating SVM...")

    svm_cal = CalibratedClassifierCV(best_svm_raw, cv=3)
    svm_cal.fit(X_train_text, y_train)

    pred2 = svm_cal.predict(X_test_text)
    probs2 = svm_cal.predict_proba(X_test_text)[:,1]

    evaluate(
        y_test,
        pred2,
        probs2,
        "Tuned TFIDF + LinearSVC + Calibration"
    )


    joblib.dump(best_lr, "best_logistic_model.joblib")
    joblib.dump(svm_cal, "best_svm_model.joblib")

    print("\nModels Saved.")
 run_baselines_hyperparameter_tuning(train_df, test_df)
plot_all_models()
plot_group_roc()



