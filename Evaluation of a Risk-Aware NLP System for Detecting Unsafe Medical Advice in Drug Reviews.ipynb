def run_baselines(train_df,test_df):
    vec=TfidfVectorizer(max_features=40000,ngram_range=(1,2),min_df=2)
    X_train=vec.fit_transform(train_df['text'])
    X_test=vec.transform(test_df['text'])
    y_train=train_df[LABEL_COL].values
    y_test=test_df[LABEL_COL].values

    # Logistic Regression
    lr=LogisticRegression(max_iter=3000,class_weight='balanced')
    lr.fit(X_train,y_train)
    pred=lr.predict(X_test)
    probs=lr.predict_proba(X_test)[:,1]
    evaluate(y_test,pred,probs,'TFIDF + Logistic Regression')

    # SVM + Calibration
    svm=LinearSVC(class_weight='balanced')
    svm_cal=CalibratedClassifierCV(svm,cv=3)
    svm_cal.fit(X_train,y_train)
    pred2=svm_cal.predict(X_test)
    probs2=svm_cal.predict_proba(X_test)[:,1]
    evaluate(y_test,pred2,probs2,'TFIDF + LinearSVC + Calibration')

    joblib.dump(vec,'tfidf_vectorizer.joblib')
    joblib.dump(svm_cal,'risk_baseline_model.joblib')

def run_transformer(train_df, test_df):

    if not USE_TRANSFORMER:
        print("Transformers not installed.")
        return

    train_part, val_part = train_test_split(
        train_df,
        test_size=0.15,
        random_state=42,
        stratify=train_df[LABEL_COL]
    )

    print("Train Size :", len(train_part))
    print("Val Size   :", len(val_part))
    print("Test Size  :", len(test_df))

    print("Loading Tokenizer...")
    tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)


    train_ds = Dataset.from_pandas(
        train_part.rename(columns={LABEL_COL: "label"})
    )

    val_ds = Dataset.from_pandas(
        val_part.rename(columns={LABEL_COL: "label"})
    )

    test_ds = Dataset.from_pandas(
        test_df.rename(columns={LABEL_COL: "label"})
    )

    def tokenize(batch):
        return tokenizer(
            batch["text"],
            padding="max_length",
            truncation=True,
            max_length=128
        )

    train_ds = train_ds.map(tokenize, batched=True)
    val_ds   = val_ds.map(tokenize, batched=True)
    test_ds  = test_ds.map(tokenize, batched=True)

    cols = ["input_ids", "attention_mask", "label"]

    train_ds.set_format(type="torch", columns=cols)
    val_ds.set_format(type="torch", columns=cols)
    test_ds.set_format(type="torch", columns=cols)

    print("Loading Model...")

    model = AutoModelForSequenceClassification.from_pretrained(
        MODEL_NAME,
        num_labels=2
    )


    def compute_metrics(eval_pred):

        logits, labels = eval_pred
        preds = np.argmax(logits, axis=1)

        acc  = accuracy_score(labels, preds)
        prec = precision_score(labels, preds, zero_division=0)
        rec  = recall_score(labels, preds, zero_division=0)
        f1   = f1_score(labels, preds, zero_division=0)

        return {
            "accuracy": acc,
            "precision": prec,
            "recall": rec,
            "f1": f1
        }


    args = TrainingArguments(
        output_dir="risk_outputs",
        num_train_epochs=10,

        per_device_train_batch_size=128,
        per_device_eval_batch_size=128,

        learning_rate=2e-5,
        fp16=True,

        logging_steps=50,

        eval_strategy="epoch",
        save_strategy="epoch",

        load_best_model_at_end=True,
        metric_for_best_model="eval_loss",

        report_to="none"
    )

    trainer = Trainer(
        model=model,
        args=args,
        train_dataset=train_ds,
        eval_dataset=val_ds,     # VALIDATION DATA
        compute_metrics=compute_metrics
    )

    print("Training Started...")
    trainer.train()

    logs = trainer.state.log_history

    train_loss = []
    val_loss = []
    val_acc = []
    val_prec = []
    val_rec = []
    val_f1 = []
    epochs = []

    for x in logs:

        if "loss" in x and "epoch" in x:
            train_loss.append(x["loss"])

        if "eval_loss" in x:
            epochs.append(int(x["epoch"]))
            val_loss.append(x["eval_loss"])
            val_acc.append(x["eval_accuracy"])
            val_prec.append(x["eval_precision"])
            val_rec.append(x["eval_recall"])
            val_f1.append(x["eval_f1"])


    train_preds = trainer.predict(train_ds)
    train_y_pred = np.argmax(train_preds.predictions, axis=1)

    train_acc = accuracy_score(
        train_part[LABEL_COL].values,
        train_y_pred
    )

    print("\nFinal Train Accuracy :", round(train_acc,4))


    print("\nRunning on Test Set...")

    test_preds = trainer.predict(test_ds)

    y_pred = np.argmax(test_preds.predictions, axis=1)

    probs = torch.softmax(
        torch.tensor(test_preds.predictions),
        dim=1
    )[:,1].numpy()

    test_acc = accuracy_score(
        test_df[LABEL_COL].values,
        y_pred
    )

    print("Final Test Accuracy :", round(test_acc,4))

    evaluate(
        test_df[LABEL_COL].values,
        y_pred,
        probs,
        "Transformer DistilBERT"
    )


    plt.figure(figsize=(10,5))

    plt.plot(
        range(1, len(train_loss)+1),
        train_loss,
        marker='o',
        label="Train Loss"
    )

    plt.plot(
        epochs,
        val_loss,
        marker='s',
        label="Validation Loss"
    )

    plt.title("Training vs Validation Loss")
    plt.xlabel("Epoch")
    plt.ylabel("Loss")
    plt.legend()
    plt.grid(True)
    plt.show()


    plt.figure(figsize=(10,5))

    plt.plot(
        epochs,
        val_acc,
        marker='o',
        linewidth=2,
        label="Validation Accuracy"
    )

    plt.axhline(
        train_acc,
        linestyle='--',
        linewidth=2,
        label="Train Accuracy"
    )

    plt.axhline(
        test_acc,
        linestyle=':',
        linewidth=2,
        label="Test Accuracy"
    )

    plt.title("Train / Validation / Test Accuracy")
    plt.xlabel("Epoch")
    plt.ylabel("Accuracy")
    plt.legend()
    plt.grid(True)
    plt.show()


    results_df = pd.DataFrame({
        "Epoch": epochs,
        "Val Loss": val_loss,
        "Val Acc": val_acc,
        "Val Precision": val_prec,
        "Val Recall": val_rec,
        "Val F1": val_f1
    })

    print("\nEpoch Wise Validation Metrics:\n")
    print(results_df)

    trainer.save_model("risk_transformer_model")
    tokenizer.save_pretrained("risk_transformer_model")

    print("Model Saved.")
def explain_text(text):
    txt=clean_text(text)
    hits=[]
    for p in RISK_PATTERNS:
        if re.search(p,txt):
            hits.append(p)
    return hits
def predict_new(text):
    model=joblib.load('risk_baseline_model.joblib')
    vec=joblib.load('tfidf_vectorizer.joblib')
    t=clean_text(text)
    X=vec.transform([t])
    prob=model.predict_proba(X)[0][1]
    pred=int(prob>=0.5)
    print('TEXT:',text)
    print('Risk Probability:',round(float(prob),4))
    print('Prediction:', 'UNSAFE' if pred==1 else 'SAFE')
    print('Triggers:', explain_text(text))
