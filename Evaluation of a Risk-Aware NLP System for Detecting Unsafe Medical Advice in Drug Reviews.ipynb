import warnings
warnings.filterwarnings("ignore")
RISK_PATTERNS=[
    r'double the dose', r'take more than prescribed', r'skip doctor',
    r'dont need doctor', r'don t need doctor', r'stop .* immediately',
    r'mix .* alcohol', r'share this medicine', r'works for everyone',
    r'increase dosage yourself', r'ignore side effects',
    r'no prescription needed', r'take two extra', r'self medicate'
]
SAFE_PATTERNS=[
    r'consult your doctor', r'ask your doctor', r'follow prescription',
    r'physician advised', r'doctor told me'
]
def clean_text(x):
    x=str(x).lower()
    x=re.sub(r'<.*?>',' ',x)
    x=re.sub(r'[^a-z0-9\s]',' ',x)
    x=re.sub(r'\s+',' ',x).strip()
    return x
def weak_label(text):
    t=clean_text(text)
    risk=sum(bool(re.search(p,t)) for p in RISK_PATTERNS)
    safe=sum(bool(re.search(p,t)) for p in SAFE_PATTERNS)
    if risk>0 and risk>=safe:
        return 1
    return 0
def load_dataset(path):
    df=pd.read_csv(path)
    print(df.head())
    df=df.dropna(subset=[TEXT_COL]).copy()
    df['text']=df[TEXT_COL].astype(str).apply(clean_text)
    df[LABEL_COL]=df['text'].apply(weak_label)
    return df
def expected_calibration_error(y_true, probs, n_bins=10):

    bins = np.linspace(0, 1, n_bins + 1)
    bin_ids = np.digitize(probs, bins) - 1

    ece = 0

    for i in range(n_bins):
        mask = bin_ids == i

        if np.sum(mask) > 0:
            acc = np.mean(y_true[mask] == (probs[mask] >= 0.5))
            conf = np.mean(probs[mask])

            ece += (np.sum(mask) / len(y_true)) * abs(acc - conf)

    return ece
def reliability_plot(y_true, probs, n_bins=10):

    bins = np.linspace(0,1,n_bins+1)

    accs = []
    confs = []

    for i in range(n_bins):
        mask = (probs >= bins[i]) & (probs < bins[i+1])

        if np.sum(mask) > 0:
            acc = np.mean(y_true[mask] == (probs[mask] >= 0.5))
            conf = np.mean(probs[mask])

            accs.append(acc)
            confs.append(conf)

    plt.figure(figsize=(6,6))
    plt.plot([0,1],[0,1],'--',label='Perfect Calibration')
    plt.plot(confs, accs, marker='o', linewidth=2)
    plt.xlabel("Confidence")
    plt.ylabel("Accuracy")
    plt.title("Reliability Diagram")
    plt.legend()
    plt.grid(True)
    plt.show()
all_results = []
roc_storage = []
def evaluate(y_true, y_pred, probs=None, name="Model"):

    acc = accuracy_score(y_true, y_pred)
    prec = precision_score(y_true, y_pred, zero_division=0)
    rec = recall_score(y_true, y_pred, zero_division=0)
    f1 = f1_score(y_true, y_pred, zero_division=0)

    roc_auc = None
    pr_auc = None
    ece = None

    if probs is not None:
        ece = expected_calibration_error(
            np.array(y_true),
            np.array(probs)
        )

    if probs is not None:
        try:
            roc_auc = roc_auc_score(y_true, probs)
            pr_auc = average_precision_score(y_true, probs)
        except:
            pass


    print(name)


    print(f"Accuracy      : {acc:.4f}")
    print(f"Precision     : {prec:.4f}")
    print(f"Recall        : {rec:.4f}")
    print(f"F1 Score      : {f1:.4f}")

    if roc_auc is not None:
        print(f"ROC-AUC       : {roc_auc:.4f}")

    if pr_auc is not None:
        print(f"PR-AUC        : {pr_auc:.4f}")

    if ece is not None:
        print(f"ECE           : {ece:.4f}")

    reliability_plot(y_true, probs)
    print("\nClassification Report:\n")
    print(classification_report(y_true, y_pred, digits=4))

    cm = confusion_matrix(y_true, y_pred)

    print("Confusion Matrix:")



    all_results.append({
        "Model": name,
        "Accuracy": acc,
        "Precision": prec,
        "Recall": rec,
        "F1 Score": f1,
        "ROC-AUC": roc_auc if roc_auc else 0
    })


    plt.figure(figsize=(6,5))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=['Safe', 'Unsafe'],
                yticklabels=['Safe', 'Unsafe'])
    plt.title(f'{name} - Confusion Matrix')
    plt.xlabel("Predicted")
    plt.ylabel("Actual")
    plt.show()


    if probs is not None:
        try:
            fpr, tpr, _ = roc_curve(y_true, probs)


            roc_storage.append({
                "name": name,
                "fpr": fpr,
                "tpr": tpr,
                "auc": roc_auc
            })

            plt.figure(figsize=(7,5))
            plt.plot(fpr, tpr, label=f"AUC = {roc_auc:.4f}")
            plt.plot([0,1], [0,1], '--')
            plt.title(f'{name} - ROC Curve')
            plt.xlabel("False Positive Rate")
            plt.ylabel("True Positive Rate")
            plt.legend()
            plt.show()
        except:
            pass

def plot_all_models():

    df = pd.DataFrame(all_results)

    print(df)

    metrics = ["Accuracy", "Precision", "Recall", "F1 Score", "ROC-AUC"]

    palettes = {
        "Accuracy": "viridis",
        "Precision": "magma",
        "Recall": "crest",
        "F1 Score": "flare",
        "ROC-AUC": "cubehelix"
    }

    for metric in metrics:

        plt.figure(figsize=(10,5))

        sns.barplot(
            x="Model",
            y=metric,
            data=df,
            palette=palettes[metric]
        )

        plt.title(f'Model Comparison - {metric}', fontsize=15, fontweight='bold')
        plt.xlabel("Models", fontsize=12)
        plt.ylabel(metric, fontsize=12)

        plt.xticks(rotation=20, fontsize=10)
        plt.yticks(fontsize=10)

        plt.ylim(0,1)

        # value labels
        for i, val in enumerate(df[metric]):
            plt.text(i, val + 0.01, f"{val:.3f}", ha='center', fontsize=10)

        plt.grid(axis='y', linestyle='--', alpha=0.4)

        plt.tight_layout()
        plt.show()
def plot_group_roc():

    plt.figure(figsize=(10,7))

    colors = ['blue', 'red', 'green', 'purple', 'orange']

    for i, item in enumerate(roc_storage):

        plt.plot(
            item["fpr"],
            item["tpr"],
            linewidth=2,
            color=colors[i % len(colors)],
            label=f"{item['name']} (AUC={item['auc']:.3f})"
        )

    plt.plot([0,1], [0,1], 'k--')

    plt.title("ROC Curve Comparison of All Models")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.legend()
    plt.grid(alpha=0.3)
    plt.show()
